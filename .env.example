# Line Login（正式環境需設定才能使用 LINE 登入）
# 至 https://developers.line.biz/ 建立 LINE Login Channel
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# 本地開發時，Callback URL 請設為：http://localhost:3000/api/auth/line/callback
# 正式環境請設為：https://你的網域/api/auth/line/callback

# 正式環境 BASE_URL（選填，預設會從 request 取得）
# BASE_URL=https://你的網域
